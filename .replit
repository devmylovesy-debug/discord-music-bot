modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Music Bot"

[[workflows.workflow]]
name = "Discord Music Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node src/index.js"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["node", "src/index.js"]
